Group {
 name GrainCustom
 inputs 2
 help "by Daniel van der Kaaden\nversion 2.4.3"
 knobChanged "\nif nuke.thisKnob().name() == 'inputChange':\n    if nuke.thisNode().input(1) == None :\n        if not nuke.thisNode().knob('maskChannelMask').value() == 'none':\n            nuke.thisNode().knob('maskInputStorer').setValue(nuke.thisNode().knob('maskChannelMask').value())   \n        nuke.thisNode().knob('maskChannelMask').setValue('none')\n    else:\n        nuke.thisNode().knob('maskChannelMask').setValue(nuke.thisNode().knob('maskInputStorer').value())\n"
 addUserKnob {20 User}
 addUserKnob {52 maskInputCheck T "nuke.thisNode().knob(\"knobChanged\").setValue(\"\"\nif nuke.thisKnob().name() == \"inputChange\":\n    if nuke.thisNode().input(1) == None :\n        if not nuke.thisNode().knob(\"maskChannelMask\").value() == \"none\":\n            nuke.thisNode().knob(\"maskInputStorer\").setValue(nuke.thisNode().knob(\"maskChannelMask\").value())   \n        nuke.thisNode().knob(\"maskChannelMask\").setValue(\"none\")\n    else:\n        nuke.thisNode().knob(\"maskChannelMask\").setValue(nuke.thisNode().knob(\"maskInputStorer\").value())\n\"\")" +STARTLINE}
 addUserKnob {26 GrainSizeDividerLine l "@b Size"}
 addUserKnob {41 GrainSizeRed l red T NoOp1.GrainSizeRed}
 addUserKnob {41 GrainSizeGreen l green T NoOp1.GrainSizeGreen}
 addUserKnob {41 GrainSizeBlue l blue T NoOp1.GrainSizeBlue}
 addUserKnob {26 GrainIntensityDividerLine l "@b Intensity"}
 addUserKnob {41 GrainIntensityRed l red T NoOp1.GrainIntensityRed}
 addUserKnob {41 GrainIntensityGreen l green T NoOp1.GrainIntensityGreen}
 addUserKnob {41 GrainIntensityBlue l blue T NoOp1.GrainIntensityBlue}
 addUserKnob {26 maskDividerLine l "@b Key"}
 addUserKnob {41 lumaKey l "mask luminance" T NoOp1.lumaKey}
 addUserKnob {41 cbTestKey l "test key" T NoOp1.cbTestKey}
 addUserKnob {41 blackpoint T Grade1.blackpoint}
 addUserKnob {41 whitepoint T Grade1.whitepoint}
 addUserKnob {41 black l lift T Grade1.black}
 addUserKnob {41 white l gain T Grade1.white}
 addUserKnob {41 multiply T Grade1.multiply}
 addUserKnob {41 gamma T Grade1.gamma}
 addUserKnob {26 maskline l "" +STARTLINE}
 addUserKnob {26 maskText l mask T ""}
 addUserKnob {41 maskChannelMask l "" -STARTLINE T Merge5.maskChannelMask}
 addUserKnob {41 inject -STARTLINE T Merge5.inject}
 addUserKnob {41 invert_mask l invert -STARTLINE T Merge5.invert_mask}
 addUserKnob {41 fringe -STARTLINE T NoOp1.fringe}
 addUserKnob {41 maskMix l mix T NoOp1.maskMix}
 addUserKnob {26 ""}
 addUserKnob {41 premult T NoOp1.premult}
 addUserKnob {26 deviderPremult l "" +STARTLINE}
 addUserKnob {22 exportFringe l "Export Fringe" t "Export a duplicate of this node with the mask option set correctly for using as a fringe grain." T "#store node\nn = nuke.thisNode()\n\n\n\nnuke.root().end()\n#deselect all nodes\nfor i in nuke.selectedNodes():\n    i.knob(\"selected\").setValue(False)\n\n#copy paste\n\nn.knob(\"selected\").setValue(True)\n\nnuke.nodeCopy(nukescripts.cut_paste_file())\nn = nuke.nodePaste(nukescripts.cut_paste_file())\n\n#set attributes\nn.knob(\"maskChannelMask\").setValue(\"rgba.alpha\")\nn.knob(\"maskMix\").setValue(.5)\nn.knob(\"fringe\").setValue(1)\nn.knob(\"label\").setValue(\"FRINGE\")\n\n#clear input\nn.knob(\"selected\").setValue(True)\nnuke.extractSelected()\t\n#set position\nn.setYpos(n.ypos() + 300)\nn.setXpos(n.xpos() - 300)" +STARTLINE}
 addUserKnob {1 maskInputStorer +INVISIBLE}
 maskInputStorer alpha
}
 Input {
  inputs 0
  name Input
  xpos 347
  ypos -733
 }
 Dot {
  name Dot1
  xpos 381
  ypos -617
 }
set N8fe7d800 [stack 0]
 Dot {
  name Dot2
  xpos 24
  ypos -617
 }
