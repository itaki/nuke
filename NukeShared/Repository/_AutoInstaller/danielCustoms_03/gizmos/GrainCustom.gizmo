 }
 NoOp {
  inputs 0
  name NoOp1
  knobChanged "c = nuke.thisNode().knob('lumaKey').value()\np = nuke.thisNode().knob('testKey')\nif c == True:\n    p.setEnabled(True)\n    p.setValue(False)\n\nelse:\n    p.setEnabled(False)\n"
  xpos 998
  ypos -485
  addUserKnob {20 User}
  addUserKnob {6 premult +STARTLINE}
  premult true
  addUserKnob {7 maskMix l mix}
  maskMix 1
  addUserKnob {6 fringe t "mask the values in between 1 and 0" +STARTLINE}
  addUserKnob {6 cbTestKey +STARTLINE}
  addUserKnob {6 lumaKey +STARTLINE}
  lumaKey true
  addUserKnob {14 GrainSizeRed R 0 100}
  GrainSizeRed 3.3
  addUserKnob {14 GrainSizeGreen R 0 100}
  GrainSizeGreen 2.9
  addUserKnob {14 GrainSizeBlue R 0 100}
  GrainSizeBlue 2.5
  addUserKnob {7 GrainIntensityRed}
  GrainIntensityRed 0.416
  addUserKnob {7 GrainIntensityGreen}
  GrainIntensityGreen 0.46
  addUserKnob {7 GrainIntensityBlue}
  GrainIntensityBlue 0.85
 }
end_group
