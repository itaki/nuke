  name Copy2
  xpos 600
  ypos -333
 }
 Premult {
  name Premult1
  xpos 600
  ypos 63
 }
push $N8febb000
 Grain2 {
  name Grain2_1
  label "Kodak 5248"
  red_size {{parent.NoOp1.GrainSizeRed}}
  green_size {{parent.NoOp1.GrainSizeGreen}}
  blue_size {{parent.NoOp1.GrainSizeBlue}}
  red_m {{parent.NoOp1.GrainIntensityRed}}
  green_m {{parent.NoOp1.GrainIntensityGreen}}
  blue_m {{parent.NoOp1.GrainIntensityBlue}}
  black {0 0 0}
  minimum {0 0 0}
 }
 Merge2 {
  inputs 2
  name Merge1
  xpos 347
  ypos 63
  disable {{parent.NoOp1.lumaKey==0?1:0}}
 }
 Merge2 {
